{
    "AWSEBDockerrunVersion": "2",
    "containerDefinitions": [
        {
            "name": "grainbank",
            "image": "882961514172.dkr.ecr.ap-northeast-2.amazonaws.com/grainbank-api-dev-ecr:v1.0.1",
            "essential": true,
            "memory": 1024,
            "portMappings": [
                {
                    "hostPort": 8000,
                    "containerPort": 8000
                }
            ],
            "environment": [
                {
                    "name": "SERVER_ENV",
                    "value": "dev"
                }
            ],
            "networkMode": "host",
            "links": ["redis", "postgres"]
        },
        {
            "name": "redis",
            "image": "redis:7",
            "essential": true,
            "memory": 1024,
            "networkMode": "host",
            "portMappings": [
                {
                    "hostPort": 6379,
                    "containerPort": 6379
                }
            ]
        },
        {
            "name": "postgres",
            "image": "postgres:16",
            "essential": true,
            "memory": 1024,
            "networkMode": "host",
            "portMappings": [
                {
                    "hostPort": 5432,
                    "containerPort": 5432
                }
            ],
            "environment": [
                {
                    "name": "POSTGRES_USER",
                    "value": "postgres"
                },
                {
                    "name": "POSTGRES_PASSWORD",
                    "value": "Rmfpdlsqodzm!12"
                },
                {
                    "name": "POSTGRES_DB",
                    "value": "cash3kki"
                }
            ]
        }
    ]
}